# ── DevPlanet · Variáveis de ambiente ─────────────────────────
# Copie este arquivo para .env e preencha com seus dados reais.

# 1. Crie um GitHub OAuth App em:
#    https://github.com/settings/developers → "New OAuth App"
#    → Homepage URL: http://localhost:3000
#    → Authorization callback URL: http://localhost:3000/auth/github/callback

GITHUB_CLIENT_ID=cole_seu_client_id_aqui
GITHUB_CLIENT_SECRET=cole_seu_client_secret_aqui
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# 2. Qualquer string aleatória para assinar as sessões
SESSION_SECRET=troque-por-uma-string-aleatoria-longa

# 3. Porta (opcional, padrão 3000)
PORT=3000
